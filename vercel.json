{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/(assets|img)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/(about|catalog|articles|contacts|certificate|guide|privacy|offer)",
      "dest": "/$1.php"
    },
    {
      "src": "/",
      "dest": "/index.php"
    },
    {
      "src": "/(.*).php",
      "dest": "/$1.php"
    }
  ]
}
